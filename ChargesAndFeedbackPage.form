    private void jButton2ActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_jButton2ActionPerformed
    String appointmentId = jTextField1.getText().trim();  // Appointment ID
    String doctorId = jTextField3.getText().trim();    // Doctor ID
    String comment = jTextArea1.getText().trim();      // Comment text
    String rate = jTextField4.getText().trim() + "/5";     // Rate

    if (appointmentId.isEmpty() || doctorId.isEmpty() || comment.isEmpty()) {
        JOptionPane.showMessageDialog(this, "Please fill all fields!", "Error", JOptionPane.ERROR_MESSAGE);
        return;
    }
    
    File file1 = new File("txtfiles/DoctorChargesAndFeedback.txt");
    File file = new File("txtfiles/DoctorHistory.txt");
    
    String name = "";
    String treatment = "";
    String charge = "";
    String dFeedback = "";
    
    
    try (Scanner sc = new Scanner(new File("txtfiles/DoctorChargesAndFeedback.txt"))){
            while (sc.hasNextLine()){
                String line = sc.nextLine().trim();
                if(!line.isEmpty()){
                    String [] parts = line.split(",");
                    if (parts[0].equals(appointmentId)){
                        name = parts[2];
                        treatment = parts[3];
                        charge = parts[4];
                        dFeedback = parts[5];
                    }
                }
            }
        }catch (FileNotFoundException ex) {
            JOptionPane.showMessageDialog(this, "DoctorChargesAndFeedback.txt not found!");
        }

    try (BufferedWriter bw = new BufferedWriter(new FileWriter(file, true))) {
        // Append new comment line
        bw.write(name + "," + treatment + "," + charge + "," + dFeedback + "," + comment + "," + rate);
        bw.newLine();
        JOptionPane.showMessageDialog(this, "Comment submitted successfully!");

        // Clear fields after sending
        jTextField1.setText("");
        jTextField3.setText("");
        jTextArea1.setText("");
        jTextField4.setText("");

    } catch (IOException e) {
        JOptionPane.showMessageDialog(this, "Error writing to file: " + e.getMessage());
    }
    }//GEN-LAST:event_jButton2ActionPerformed


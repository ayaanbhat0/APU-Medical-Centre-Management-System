    private void jButton2ActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_jButton2ActionPerformed
        String id = jTextField1.getText().trim();       // Entered ID
        String newName = jTextField2.getText().trim();  // New Name
        String newEmail = jTextField8.getText().trim(); // New Email
        String newPassword = jTextField4.getText().trim(); // New Password
        String newGender = jComboBox1.getSelectedItem().toString().trim(); //New Gender
        String newAge = jTextField5.getText().trim(); // New Age
        String newPhone = jTextField3.getText().trim(); // New Phone Number

        File file = new File("txtfiles/customer.txt");
        List<String> updatedLines = new ArrayList<>();

        boolean updated = false;

        try (BufferedReader br = new BufferedReader(new FileReader(file))) {
            String line;
            while ((line = br.readLine()) != null) {
                String[] parts = line.split(",");

                // Make sure line has all fields
                if (parts.length >= 7 && parts[0].equalsIgnoreCase(id)) {
                    // Replace only changed fields
                    if (!newName.isEmpty()) parts[1] = newName;
                    if (!newPassword.isEmpty()) parts[2] = newPassword;
                    if (!newEmail.isEmpty()) parts[4] = newEmail;

                    // Rebuild the updated line
                    line = String.join(",", parts);
                    updated = true;
                }

                updatedLines.add(line);
            }
        } catch (IOException e) {
            JOptionPane.showMessageDialog(this, "Error reading file: " + e.getMessage());
            return;
        }

        // Write updated content back to file
        if (updated) {
            try (BufferedWriter bw = new BufferedWriter(new FileWriter(file))) {
                for (String updatedLine : updatedLines) {
                    bw.write(updatedLine);
                    bw.newLine();
                }
                JOptionPane.showMessageDialog(this, "Profile updated successfully!");
            } catch (IOException e) {
                JOptionPane.showMessageDialog(this, "Error writing file: " + e.getMessage());
            }
        } else {
            JOptionPane.showMessageDialog(this, "Customer ID not found!", "Error", JOptionPane.ERROR_MESSAGE);
        }
    }//GEN-LAST:event_jButton2ActionPerformed


    private void jButton1ActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_jButton1ActionPerformed
        new DoctorMainPage().openPage();
        closePage();
    }//GEN-LAST:event_jButton1ActionPerformed

    private void loadAppointments() {
        DefaultTableModel model = (DefaultTableModel) tblAppointments.getModel();
        model.setRowCount(0); // clear existing rows

        try (BufferedReader br = new BufferedReader(new FileReader("txtfiles/appointments.txt"))) {
            String line;
            while ((line = br.readLine()) != null) {
                String[] data = line.split(",");
                if (data.length >= 8) { 
                    // Pick 1,2,3,4,8th rows
                    model.addRow(new Object[]{data[0], data[1], data[2], data[3], data[7]});
                }
            }
        } catch (IOException ex) {
            JOptionPane.showMessageDialog(this, "Error loading appointments: " + ex.getMessage());
        }
    }
    

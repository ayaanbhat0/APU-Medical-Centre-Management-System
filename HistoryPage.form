    private void btnSaveActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnSaveActionPerformed
        String selectedPatient = (String) cmbPatient.getSelectedItem();
        if (selectedPatient == null) {
            JOptionPane.showMessageDialog(this, "Please select a patient.");
            return;
        }

        // Now we should extract PatientID properly
        // Assuming comboBox item looks like "B01 - C01 - John Doe (Flu) | RM 100 | Recovered well"
        String[] splitParts = selectedPatient.split(" - ");
        if (splitParts.length < 2) {
            JOptionPane.showMessageDialog(this, "Invalid patient format!");
            return;
        }

        String patientId = splitParts[1].trim();  // C01
        String charges = txtCharges.getText().trim();
        String feedback = txtFeedback.getText().trim();

        if (charges.isEmpty() || feedback.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Please enter charges and feedback.");
            return;
        }

        File originalFile = new File("txtfiles/DoctorChargesAndFeedback.txt");
        File tempFile = new File("txtfiles/DoctorChargesAndFeedback.tmp");

        try (BufferedReader br = new BufferedReader(new FileReader(originalFile));
             BufferedWriter bw = new BufferedWriter(new FileWriter(tempFile))) {

            String line;
            boolean updated = false;
            while ((line = br.readLine()) != null) {
                String[] parts = line.split(",");
                if (parts.length >= 4 && parts[1].equals(patientId)) {
                    // Update charges + feedback
                    line = parts[0] + "," + parts[1] + "," + parts[2] + "," + parts[3] + "," 
                           + charges + "," + feedback.replace(",", ";");
                    updated = true;
                }
                bw.write(line);
                bw.newLine();
            }

            if (!updated) {
                JOptionPane.showMessageDialog(this, "Patient not found in file. No new entry added.");
            }

        } catch (IOException e) {
            JOptionPane.showMessageDialog(this, "Error saving data: " + e.getMessage());
            return;
        }

        // Replace old file with updated one
        if (!originalFile.delete() || !tempFile.renameTo(originalFile)) {
            JOptionPane.showMessageDialog(this, "Error updating file!");
        } else {
            JOptionPane.showMessageDialog(this, "Saved successfully!");
            txtCharges.setText("");
            txtFeedback.setText("");
            loadPatients(); // Refresh combo box
        }
    }//GEN-LAST:event_btnSaveActionPerformed

    private void loadPatients() {
        cmbPatient.removeAllItems(); // clear existing items
        try (BufferedReader br = new BufferedReader(new FileReader("txtfiles/DoctorChargesAndFeedback.txt"))) {
            String line;
            while ((line = br.readLine()) != null) {
                String[] parts = line.split(",");
                if (parts.length >= 4) {
                    // Show BookingID + PatientID + Name + Treatment
                    String item = parts[0] + " - " + parts[1] + " - " + parts[2] + " (" + parts[3] + ")";

                    // If charges and feedback exist, add them too
                    if (parts.length >= 6) {
                        item += " | RM " + parts[4] + " | " + parts[5];
                    }
                    cmbPatient.addItem(item);
                }
            }
        } catch (IOException e) {
            JOptionPane.showMessageDialog(this, "Error loading patients!");
        }
    }
    
